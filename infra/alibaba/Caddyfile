# Ayin — HTTPS front (Alibaba Cloud ECS). Caddy auto-provisions Let's
# Encrypt when PUBLIC_HOST is a domain; for a bare ECS IP it falls back to
# its internal CA (judges get TLS either way; a cheap domain is nicer).

{$PUBLIC_HOST} {
	encode gzip

	# API under /api → FastAPI
	handle_path /api/* {
		reverse_proxy api:8000 {
			# OVERWRITE (not append) X-Forwarded-For with the real client IP that
			# Caddy actually saw, discarding any client-supplied X-Forwarded-For.
			# uvicorn --proxy-headers then reads a single trusted value, so the
			# per-IP consent throttle can't be spoofed/rotated by a client.
			header_up X-Forwarded-For {remote_host}
		}
	}

	# everything else → Next.js
	handle {
		reverse_proxy web:3000
	}
}
