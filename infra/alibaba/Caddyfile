# Ayin — HTTPS front (Alibaba Cloud ECS). Caddy auto-provisions Let's
# Encrypt when PUBLIC_HOST is a domain; for a bare ECS IP it falls back to
# its internal CA (judges get TLS either way; a cheap domain is nicer).

{$PUBLIC_HOST} {
	encode gzip

	# HSTS — .com isn't on the HSTS preload list, so enforce HTTPS at the
	# browser ourselves. (Browsers ignore HSTS on a bare IP, so this is a
	# harmless no-op until PUBLIC_HOST is the real domain.)
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# API under /api → FastAPI
	handle_path /api/* {
		reverse_proxy api:8000
	}

	# everything else → Next.js
	handle {
		reverse_proxy web:3000
	}
}
