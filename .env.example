# Ayin — environment template.
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# Use clearly-fake values in any shared/example context.

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET=change-me-generate-a-long-random-string
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# ── Postgres (operational + findings) ─────────────────────────
POSTGRES_USER=ayin
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=ayin
DATABASE_URL=postgresql://ayin:change-me-local-only@localhost:5432/ayin

# ── Redis (cache, rate-limit, Celery broker) ──────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object storage (raw scan artifacts) — MinIO locally ───────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ayin-artifacts
S3_ACCESS_KEY=change-me-local-only
S3_SECRET_KEY=change-me-local-only

# ── PII vault ─────────────────────────────────────────────────
# Master key for field-level encryption / crypto-shred. In production
# this comes from a KMS, NOT an env var. Local dev only here.
VAULT_MASTER_KEY=change-me-generate-a-32-byte-base64-key
PII_RETENTION_DAYS=30

# ── Data source connectors (MVP) ──────────────────────────────
# Breach/credential provider (HIBP-class). Detect exposure only —
# never store or display full plaintext secrets.
BREACH_API_KEY=
BREACH_API_BASE_URL=

# Public-web / social search provider (compliant search API).
SEARCH_API_KEY=
SEARCH_API_BASE_URL=

# Data-broker detection: path to the curated broker registry/playbook.
BROKER_REGISTRY_PATH=./backend/ayin/connectors/broker/registry.yaml

# ── Safety / limits (FR-SCAN-3) — these only SEED the
#    rate_limit_policies table; change the DB row to tune live ─
RATE_LIMIT_SCANS_PER_DAY=5
RATE_LIMIT_BURST=2

# ── Scan execution (M1-1): inline (dev) | celery (compose/prod) ─
SCAN_EXECUTION=inline

# ── Private beta (M5-1): gate signup behind invite codes ──────
# Manage codes with: python -m ayin.beta.invites create --count 10
BETA_INVITE_REQUIRED=false

# ── Auth / OAuth (FR-AUTH-1) ──────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
